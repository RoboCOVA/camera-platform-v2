# agent/.env.local
# Edge agent config for local macOS development

CAM_CONTROL_URL=http://localhost:3001
CAM_CONTROL_KEY=dev-device-key-local
CAM_DATA_PATH=/tmp/cam-data
CAM_FRIGATE_CONFIG=/tmp/cam-data/frigate.yml
CAM_MQTT_HOST=localhost

# Set to your local subnet to scan for real ONVIF cameras.
# Find your subnet: ifconfig en0 | grep "inet " | awk '{print $2}'
# Then set e.g. 192.168.1.0/24
# Leave blank to skip network scanning (uses cameras.json instead)
CAM_SUBNET=

# Camera credentials to try during ONVIF discovery
CAM_CRED_USER_1=admin
CAM_CRED_PASS_1=admin
