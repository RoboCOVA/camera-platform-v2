# cam-platform environment configuration
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Keycloak ─────────────────────────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change_me_strong_password_here

# ── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_API_USER=camapi
MQTT_API_PASSWORD=change_me_mqtt_password

# ── Device auth ───────────────────────────────────────────────────────────────
DEVICE_SECRET=change_me_device_secret_hex

# ── WireGuard server automation ───────────────────────────────────────────────
WG_DOCKER_CONTAINER=cam_wireguard
WG_INTERFACE=wg0

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password

# ── S3-compatible storage (optional — for cloud video archive) ────────────────
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
