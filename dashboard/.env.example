# Dashboard environment — copy to .env.local for development
# In production these are injected via Docker build args

# Backend API
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Keycloak (NextAuth)
KEYCLOAK_CLIENT_ID=cam-dashboard
KEYCLOAK_CLIENT_SECRET=your-client-secret-from-keycloak-setup
KEYCLOAK_ISSUER=https://auth.yourdomain.com/realms/camplatform

# NextAuth
NEXTAUTH_URL=https://app.yourdomain.com
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# For local dev:
# NEXT_PUBLIC_API_URL=http://localhost:3001
# KEYCLOAK_ISSUER=http://localhost:8080/realms/camplatform
# NEXTAUTH_URL=http://localhost:3000
